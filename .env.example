# =============================================================================
# Document Intelligence Refinery — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.  Never commit .env!
#
# LLM routing:
#   • OpenRouter  → Vision LLM only (Strategy D extreme extraction)
#   • Ollama      → PageIndex summaries, QueryAgent reasoning, FactTable extraction
# =============================================================================

# ── OpenRouter API (Vision LLM / Strategy D only) ──────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── OpenRouter model names (vision only) ──────────────────────────────
VISION_MODEL=google/gemma-3-27b-it:free

# ── Ollama (local LLM server) ─────────────────────────────────────
# Used for: PageIndex summaries, QueryAgent answer synthesis + audit,
#           FactTable LLM-assisted extraction.
# Falls back to deterministic methods automatically if Ollama is down.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3-coder:480b-cloud

# ── Budget & cost caps ─────────────────────────────────────────────────────
# Maximum USD budget per document extraction (vision calls)
BUDGET_MAX_PER_DOCUMENT=0.50
# Maximum vision LLM calls per document
BUDGET_MAX_VISION_CALLS=5
# Maximum LLM-assisted extraction calls per document
BUDGET_MAX_LLM_CALLS=20

# ── Confidence thresholds ──────────────────────────────────────────────────
CONFIDENCE_FAST_TEXT_MIN=0.6
CONFIDENCE_LAYOUT_MIN=0.5
CONFIDENCE_REVIEW_FLAG=0.4

# ── Feature flags ──────────────────────────────────────────────────────────
ENABLE_VISION_EXTRACTION=false
ENABLE_LLM_FACT_EXTRACTION=true
ENABLE_PAGE_LEVEL_ESCALATION=true
ENABLE_OCR_FALLBACK=true

# ── Paths ──────────────────────────────────────────────────────────────────
REFINERY_DB_PATH=.refinery/refinery.db
REFINERY_CHROMA_DIR=.refinery/chroma_store
REFINERY_LEDGER_PATH=.refinery/extraction_ledger.jsonl
REFINERY_RUNS_DIR=.refinery/runs

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
